{
  "name": "cloak",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "pg": "^8.16.3"
  },
  "scripts": {
    "migrate": "node src/database/run-migrations.js",
    "migrate:dry-run": "node src/database/run-migrations.js --dry-run",
    "migrate:status": "node src/database/run-migrations.js --status",
    "smoke:postgres": "node src/database/run-postgres-smoke-check.js",
    "smoke:postgres-api": "node src/database/run-postgres-api-smoke-check.js",
    "smoke:postgres-admin": "node src/database/run-postgres-admin-smoke-check.js",
    "preflight:postgres": "node src/database/run-production-preflight.js",
    "start": "node src/server/start.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  }
}
